@echo off
echo Resetting Terminal Environment...
echo 1. Killing all Node.js processes...
taskkill /F /IM node.exe /T 2>nul
echo 2. Clearing terminal hooks...
echo 3. Verifying Node.js environment...
node -v
npm -v
echo 4. Verifying Expo...
npx expo --version
echo.
echo Terminal Reset Complete. 
echo If the terminal is still not responding, please restart VS Code.
pause
